# Pin the package registry to public npmjs.org for this open-source repo.
#
# Without this override, a developer with a corporate-issued ~/.npmrc
# (which points at a private artifactory mirror) silently bakes the
# internal mirror URL into pnpm-lock.yaml. The lockfile
# then can't be installed by anyone outside the corporate network, and
# the URL itself becomes informational leakage when this repo is pushed
# to a public GitHub remote.
#
# Precedence: workspace .npmrc overrides ~/.npmrc for matching keys.
registry=https://registry.npmjs.org/
