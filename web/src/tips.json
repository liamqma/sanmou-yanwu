  "heroes": {
    "张春华": "张春华需要搭配司马懿才能发挥最大价值（最佳组合），搭配王异也可以（次优组合）。如果阵容中没有司马懿或王异，张春华的价值会大幅降低，评估时应降低其评分。",
    "诸葛亮2": "全能辅助，可搭配木鹿大王+祝融夫人（OP级）、甘夫人+姜维（T0级）、大乔+马超（T1+级）、乐进+张辽（T2级）。",
    "祝融夫人": "输出：木鹿大王+神诸葛（OP级）、孟获+木鹿大王（T0级）、田丰+貂蝉（T1+级）、左慈+田丰（T1级）、袁绍+曹纯（T1级）。",
    "曹丕": "智力辅助：搭配郝昭+司马懿（T0级）、甘夫人+诸葛亮（T0级）、曹操+司马懿（T1+级）。",
    "司马懿": "输出：搭配曹丕+郝昭（T0级 SS→SSS）、曹操+曹丕（T1+级）、张春华+荀彧（T1+级）。也可搭配邓艾+夏侯惇（T2级）。",
    "张宁": "输出：搭配左慈+孙坚（T0级）、左慈+田丰（T1+级）、孙权+田丰（T1+级）、田丰+陆抗（T1级）。",
    "左慈": "主动队辅助：搭配张宁+孙坚（T0级）、田丰+张宁（T1+级）、田丰+祝融夫人（T1级）。",
    "孙权": "主动队辅助：搭配陆抗+陆逊（T0级 B→SSS）、田丰+张宁（T1+级）。",
    "姜维": "输出：甘夫人+神诸葛（T0级）、甘夫人+赵云（T1级）、刘备+诸葛亮（T1级）。也可作为辅助型阵容搭配貂蝉（T2级）。",
    "陆逊": "输出：陆逊最佳搭配为孙权+陆抗（T0级 B→SSS），也可搭配步练师+左慈（T3级）。",
    "貂蝉": "辅助：貂蝉搭配田丰+祝融夫人（T1+级），也可作为辅助搭配姜维（T2级）。"
  },
  "skills": {
    "运智铺谋": "与「谋而后动」有强力联动，两者搭配可大幅提升谋略伤害。适合高智力输出武将，如王异、司马懿、诸葛亮、陆逊。",
    "谋而后动": "与「运智铺谋」有强力联动，两者搭配可大幅提升谋略伤害。适合高智力输出武将，如王异、司马懿、诸葛亮、陆逊。"
  }
